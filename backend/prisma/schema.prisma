generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventType {
  email
  meeting
  task
  document
}

model Event {
  id        String   @id @default(uuid())
  userId    String
  type      EventType
  title     String
  timestamp DateTime
  metadata  Json
}
